# EditorConfig: https://editorconfig.org
# Enforces consistent coding styles across editors and tools.

root = true

# Default settings for all files
[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = space
indent_size = 4

# Java, Kotlin, Groovy source files
[*.{java,kt,kts,groovy}]
indent_style = space
indent_size = 4

# YAML configuration files (2-space is Spring Boot convention)
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# JSON and JSONC files
[*.{json,jsonc}]
indent_style = space
indent_size = 2

# TOML, XML, SQL, Properties
[*.{toml,xml,sql,properties}]
indent_style = space
indent_size = 4

[pom.xml]
indent_style = space
indent_size = 4

# SQL files (2-space indent is common)
[*.sql]
indent_style = space
indent_size = 2

# Markdown files
[*.{md,markdown}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# Shell scripts
[*.sh]
indent_style = space
indent_size = 4

# Python files
[*.py]
indent_style = space
indent_size = 4
max_line_length = 200

# Gradle Kotlin DSL build files
[*.gradle.kts]
indent_style = space
indent_size = 4

# Makefiles (tabs required)
[Makefile]
indent_style = tab

# Dockerfile
[Dockerfile*]
indent_style = space
indent_size = 4

# Batch files require Windows line endings
[*.{bat,cmd}]
end_of_line = crlf

# Certificate and key files - preserve as-is
[*.{key,crt,pem,der}]
trim_trailing_whitespace = false
insert_final_newline = false
