# Normalize text files: store LF in the repository.
# On checkout, core.autocrlf=true (Windows default) converts to CRLF.
* text=auto

# Windows-specific files that must remain CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Explicitly classify text files (no forced eol – let core.autocrlf decide)
*.java       text
*.kt         text
*.kts        text
*.groovy     text
*.properties text
*.yml        text
*.yaml       text
*.xml        text
*.json       text
*.toml       text
*.sql        text
*.md         text
*.sh         text

# Binary files - do not attempt line ending conversion
*.class    binary
*.jar      binary
*.war      binary
*.ear      binary
*.zip      binary
*.tar      binary
*.gz       binary
*.exe      binary
*.dll      binary
*.so       binary
*.dylib    binary
*.key      binary
*.crt      binary
*.pem      binary
*.der      binary
*.p12      binary
*.pfx      binary
*.keystore binary
*.jks      binary
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.pdf      binary

# Mark Gradle wrapper jar as binary/generated (exclude from diffs and language stats)
gradle/wrapper/gradle-wrapper.jar binary linguist-generated=true
