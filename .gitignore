*.tmp
*.bak
*.swp
*.swo
*~

# Logs
*.log
logs/

# Test artifacts and coverage reports
test-output/
test-results/
workflow-reports/

# Security - never track private keys or certificates
*.pem
*.key
*.crt
*.der
*.p12
*.pfx
*.keystore
*.jks

# cspell word cache
.cspellcache
