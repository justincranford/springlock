# Gradle
.gradle/
**/build/
!src/**/build/
gradle-app.setting

# VS Code Java output
**/bin/
!src/**/bin/

# Maven
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties

# Java / JVM
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*

# Spring Boot local overrides and secrets (never commit)
application-local.properties
application-local.yml
application-local.yaml
application-secrets.properties
application-secrets.yml
.spring-boot-devtools.properties

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# Eclipse / Spring Tool Suite
.settings/
.project
.classpath
.factorypath
.apt_generated/
.sts4-cache/
*.launch

# VS Code - track team settings, ignore personal state
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/*.code-snippets

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

