{
  "$schema": "vscode://schemas/settings/user",
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": true,
    "scminput": false
  },
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,
  "github.copilot.chat.generateTests.codeLens": true,
  "github.copilot.chat.editor.temporalContext.enabled": true,
  "github.copilot.nextEditSuggestions.enabled": true,
  "chat.agentSessionsViewLocation": "view",
  "chat.agent.maxRequests": 1000,
  "chat.math.enabled": true,
  "chat.fontSize": 14,
  "chat.editor.fontSize": 14,
  "workbench.secondarySideBar.defaultVisibility": "visible",
  "workbench.editor.empty.hint": "hidden",
  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "always",
  "git.blame.editorDecoration.enabled": true,
  "terminal.integrated.fontSize": 15,
  "terminal.integrated.shellIntegration.enabled": true,
  "terminal.integrated.shellIntegration.history": 500,
  "terminal.integrated.defaultProfile.windows": "PowerShell Core",
  "terminal.integrated.profiles.windows": {
    "PowerShell Core": {
      "source": "PowerShell",
      "icon": "terminal-powershell",
      "args": [
        "-NoLogo"
      ]
    },
    "PowerShell": {
      "source": "PowerShell",
      "args": [
        "-NoLogo",
        "-ExecutionPolicy",
        "RemoteSigned"
      ]
    }
  },
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.persistentSessionReviveProcess": "never",
  "diffEditor.ignoreTrimWhitespace": false,
  "diffEditor.hideUnchangedRegions.enabled": false,
  "files.encoding": "utf8",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "files.associations": {
    "*.properties": "properties",
    "Dockerfile*": "dockerfile",
    "*.gradle.kts": "kotlin"
  },
  "files.exclude": {
    "**/.git/COMMIT_EDITMSG": true,
    "**/.git/description": true,
    "**/.git/info": true,
    "**/.git/index": true,
    "**/.git/refs": true,
    "**/.git/packed-refs": true,
    "**/.git/logs": true,
    "**/.git/lost-found": true,
    "**/.git/objects": true,
    "**/.git/FETCH_HEAD": true,
    "**/.git/ORIG_HEAD": true,
    "**/.git/HEAD": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/desktop.ini": true,
    "**/*.tmp": true,
    "**/*.swp": true,
    "**/*.swo": true,
    "**/*.class": true,
    "**/*.jar": true,
    "**/*.war": true,
    "**/*.ear": true,
    "**/build": true,
    "**/out": true,
    "**/target": true,
    "**/.gradle": true,
    "**/.mvn": true,
    "**/.idea": true,
    "**/*.iml": true,
    "**/*.iws": true,
    "**/.settings": true,
    "**/.project": true,
    "**/.classpath": true,
    "**/.sts4-cache": true,
    "**/.factorypath": true,
    "**/node_modules": true,
    "**/.cspellcache": true,
    "**/.cicd": true,
    "**/.env": true,
    "**/.venv": true,
    "**/venv": true,
    "**/ENV": true,
    "**/test-output/**": true,
    "**/test-results/**": true,
    "**/workflow-reports/**": true,
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true
  },
  "search.exclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.git/logs/**": true,
    "**/.git/lost-found/**": true,
    "**/build/**": true,
    "**/out/**": true,
    "**/target/**": true,
    "**/.gradle/**": true,
    "**/*.class": true,
    "**/*.jar": true,
    "**/*.war": true,
    "**/*.ear": true,
    "**/.idea/**": true,
    "**/node_modules": true,
    "**/test-output/**": true,
    "**/test-results/**": true,
    "**/workflow-reports/**": true,
    "**/.cspellcache": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/*.log": true
  },
  "search.useIgnoreFiles": true,
  "search.useGlobalIgnoreFiles": true,
  "search.useParentIgnoreFiles": true,
  "search.followSymlinks": false,
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.git/logs/**": true,
    "**/.git/lost-found/**": true,
    "**/build/**": true,
    "**/out/**": true,
    "**/target/**": true,
    "**/.gradle/**": true,
    "**/.mvn/**": true,
    "**/*.class": true,
    "**/*.jar": true,
    "**/.idea/**": true,
    "**/node_modules/**": true,
    "**/test-output/**": true,
    "**/test-results/**": true,
    "**/workflow-reports/**": true,
    "**/__pycache__/**": true,
    "**/.pytest_cache/**": true,
    "**/.mypy_cache/**": true,
    "**/.ruff_cache/**": true,
    "**/.tox/**": true,
    "**/.venv/**": true,
    "**/venv/**": true,
    "**/*.log": true
  },
  "markdown.preview.scrollEditorWithPreview": true,
  "markdown.preview.openMarkdownLinks": "inPreview",
  "markdown.validate.enabled": true,
  "markdown.math.enabled": true,
  "markdown.validate.fragmentLinks.enabled": "warning",
  "markdown.validate.fileLinks.enabled": "warning",
  "markdown.updateLinksOnFileMove.enabled": "prompt",
  "yaml.schemas": {
    "https://json.schemastore.org/github-workflow.json": [
      ".github/workflows/*.{yml,yaml}"
    ],
    "https://json.schemastore.org/github-action.json": [
      ".github/actions/**/*.{yml,yaml}",
      "**/action.{yml,yaml}"
    ],
    "https://json.schemastore.org/dependabot-2.0.json": [
      ".github/dependabot.yml",
      ".github/dependabot.yaml"
    ],
    "https://json.schemastore.org/pre-commit-config.json": [
      ".pre-commit-config.yml",
      ".pre-commit-config.yaml"
    ]
  },
  "yaml.format.enable": true,
  "yaml.format.singleQuote": false,
  "yaml.format.bracketSpacing": true,
  "yaml.format.proseWrap": "preserve",
  "json.schemas": [
    {
      "fileMatch": [
        "package.json"
      ],
      "url": "https://json.schemastore.org/package.json"
    }
  ],
  "editor.aiStats.enabled": true,
  "editor.rulers": [
    80,
    120,
    200
  ],
  "editor.minimap.enabled": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,
  "explorer.excludeGitIgnore": true,
  "cSpell.words": [
    "AGPL",
    "Applebot",
    "Bingbot",
    "Bytespider",
    "CCBot",
    "ClaudeBot",
    "DataForSeoBot",
    "Diffbot",
    "DuckDuckBot",
    "GPTBot",
    "Googlebot",
    "NoLogo",
    "OAI",
    "PerplexityBot",
    "RemoteSigned",
    "Scrapy",
    "autocrlf",
    "citus",
    "citusdata",
    "cohere",
    "copyleft",
    "cspellcache",
    "darkvisitors",
    "dependabot",
    "dylib",
    "factorypath",
    "gradlew",
    "justincranford",
    "linguist",
    "llms",
    "llmstxt",
    "mvnw",
    "omgili",
    "omgilibot",
    "pluggable",
    "robotstxt",
    "schemastore",
    "springlock",
    "testcontainers"
  ],
  "java.import.gradle.enabled": true,
  "java.import.gradle.wrapper.enabled": true,
  "java.import.maven.enabled": false,
  "java.compile.nullAnalysis.mode": "automatic",
  "java.saveActions.organizeImports": true,
  "java.inlayHints.parameterNames.enabled": "literals",
  "java.referencesCodeLens.enabled": true,
  "java.implementationsCodeLens.enabled": true,
  "java.test.defaultConfig": "",
  "java.configuration.updateBuildConfiguration": "automatic",
  "boot-java.live-hover.on": true,
  "maven.terminal.useJavaHome": true,
  "chat.tools.terminal.autoApprove": {
    "git push": false,
    "git pull": false,
    "git reset": false,
    "git rebase": false,
    "rm ": false,
    "del ": false,
    "Remove-Item": false,
    "Invoke-WebRequest": false,
    "Invoke-RestMethod": false,
    "gradlew": true,
    "gradlew.bat": true,
    "gradle ": true,
    "mvnw": true,
    "mvnw.cmd": true,
    "mvn ": true,
    "java ": true,
    "javac ": true,
    "docker ": true,
    "git ": true,
    "code ": true,
    "python ": true,
    "python3 ": true,
    "pip ": true,
    "pip3 ": true,
    "ls ": true,
    "which ": true,
    "find ": true,
    "grep ": true,
    "cat ": true,
    "head ": true,
    "tail ": true,
    "mkdir ": true,
    "dir ": true,
    "type ": true,
    "curl ": true,
    "jq ": true,
    "Get-ChildItem ": true,
    "Get-Content ": true,
    "Set-Content": true,
    "New-Object": true,
    "Select-Object ": true,
    "Select-String ": true,
    "Test-Path ": true,
    "Resolve-Path": true,
    "Measure-Object ": true,
    "Format-Table ": true,
    "Format-List ": true,
    "Out-String": true,
    "Get-NetTCPConnection": true,
    "ForEach-Object": true,
    "Get-Process ": true,
    "Get-Service ": true,
    "Get-Command ": true,
    "Get-Location ": true,
    "Set-Location ": true,
    "Get-Alias ": true
  }
}
